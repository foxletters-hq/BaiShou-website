---
import FeatureCard from './FeatureCard.tsx';
import { FEATURE_IDS } from '../data/site';
import {
  BookHeart,
  Sparkles,
  FolderOpen,
  Search,
  Cloud,
  Shield,
} from 'lucide-react';

const featureIcons = {
  diary: BookHeart,
  companion: Sparkles,
  knowledge: FolderOpen,
  rag: Search,
  sync: Cloud,
  local: Shield,
} as const;
---

<section id="features" class="snap-page">
  <div class="container snap-page-inner">
    <div class="reveal section-heading">
      <p class="section-eyebrow" data-i18n="features.eyebrow">Features</p>
      <h2 data-i18n="features.title">核心能力</h2>
      <p class="section-lead" data-i18n="features.lead">
        日记、AI 伙伴与同步能力已经可用；知识库正在开发，将逐步与现有记忆体系打通。
      </p>
    </div>

    <div class="features-grid reveal">
      {FEATURE_IDS.map((id) => (
        <FeatureCard
          i18nId={id}
          icon={featureIcons[id]}
          showBadge={id === 'knowledge'}
        />
      ))}
    </div>
  </div>
</section>
