---
/**
 * BaiShou 产品官网布局
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CommunityModal from '../components/CommunityModal.astro';
import DownloadPopup from '../components/DownloadPopup.astro';
import ThemeScene from '../components/ThemeScene.astro';
import UmamiAnalytics from '../components/UmamiAnalytics.astro';
import zhCN from '../i18n/locales/zh-CN';
import { getInitialLocaleScript } from '../scripts/i18n';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = zhCN.meta.title,
  description = zhCN.meta.description,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0f1e" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/images/app-icon.png" />
    <meta property="og:locale" content="zh_CN" />

    <script is:inline set:html={getInitialLocaleScript()} />
    <script is:inline>
      (function () {
        var key = 'baishou-theme';
        var stored = localStorage.getItem(key);
        var theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap"
    />
    <UmamiAnalytics />
  </head>
  <body>
    <ThemeScene />
    <div class="bg-overlay" aria-hidden="true"></div>

    <Header />
    <slot />
    <SiteFooter />
    <CommunityModal />
    <DownloadPopup />

    <script>
      import { initLenisScroll } from '../scripts/lenisScroll';
      import { initI18n } from '../scripts/i18n';

      const initReveal = () => {
        const els = document.querySelectorAll<HTMLElement>('.reveal');
        if (els.length === 0) return;

        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px' }
        );

        els.forEach((el) => observer.observe(el));
      };

      const initSnapNav = () => {
        const dots = document.querySelectorAll<HTMLElement>('[data-snap-dot]');
        const links = document.querySelectorAll<HTMLElement>('[data-nav-link]');

        const setActive = (id: string) => {
          dots.forEach((dot) => {
            dot.classList.toggle('is-active', dot.dataset.snapDot === id);
          });
          links.forEach((link) => {
            link.classList.toggle('is-active', link.dataset.navLink === id);
          });
        };

        return setActive;
      };

      const init = () => {
        initI18n();
        initReveal();
        const setActive = initSnapNav();
        initLenisScroll(setActive);
      };

      document.addEventListener('DOMContentLoaded', init);
    </script>
  </body>
</html>